<UserControl
    x:Class="ControlBeeWPF.Views.DigitalOutputStatusBarViewV2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ControlBeeWPF.ViewModels;assembly=ControlBeeWPF"
    Height="{Binding RowHeight, RelativeSource={RelativeSource Self}}"
    d:DataContext="{d:DesignInstance viewModels:DigitalOutputViewModel}"
    d:DesignHeight="40"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <Border
        Margin="2,2"
        BorderBrush="Silver"
        BorderThickness="1"
        CornerRadius="4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Name="NameColumn" Width="{Binding NameColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="0"
                Padding="8,2"
                Background="WhiteSmoke"
                CornerRadius="3,0,0,3">
                <TextBlock
                    Name="NameText"
                    VerticalAlignment="Center"
                    Text="name" />
            </Border>
            <Border
                Name="ValueBorder"
                Grid.Column="1"
                Padding="8,2"
                Background="LightGray"
                CornerRadius="0,3,3,0"
                Cursor="Hand"
                MouseLeftButtonDown="ValueBorder_OnMouseLeftButtonDown">
                <TextBlock
                    Name="ValueText"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Foreground="DimGray"
                    Text="Off" />
            </Border>
        </Grid>
    </Border>
</UserControl>
